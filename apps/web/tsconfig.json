{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@sj/crypto": ["../../packages/crypto/dist"],
      "@sj/crypto/*": ["../../packages/crypto/dist/*"],
      "@sj/ipfs": ["../../packages/ipfs/dist"],
      "@sj/ipfs/*": ["../../packages/ipfs/dist/*"],
      "@sj/storage": ["../../packages/storage/dist"],
      "@sj/storage/*": ["../../packages/storage/dist/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
