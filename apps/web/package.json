{
  "name": "@sj/web",
  "version": "0.1.0",
  "private": true,
  "description": "Sovereign Jedi — web frontend (Next.js) skeleton for Episode I: The awakening (MVP)",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.9.0",
  "next": {
    "eslint": {
      "ignoreDuringBuilds": true
    }
  },
  "scripts": {
    "dev": "next dev -p 1620",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@sj/crypto": "workspace:*",
    "@sj/ipfs": "workspace:*",
    "@sj/manifest": "workspace:*",
    "@sj/solana-registry": "workspace:^",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "libsodium-wrappers-sumo": "^0.7.16",
    "next": "^13.4.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "13.4.10",
    "husky": "^8.0.0",
    "typescript": "^5.1.6",
    "vitest": "^1.0.0"
  }
}
