{
  "name": "sovereign-jedi",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Sovereign Jedi (Episode I: The awakening) — workspace scaffold, shared scripts and CI helpers",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.9.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "bootstrap": "pnpm install",
    "test": "pnpm -r --reporter=default test",
    "build": "pnpm --filter \"packages/*\" -r build && pnpm --filter \"apps/*\" -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r --reporter=default typecheck",
    "ci": "pnpm install && pnpm -r --reporter=default test && pnpm --filter \"packages/*\" -r build && pnpm --filter \"apps/*\" -r build",
    "dev:web": "pnpm --filter @sj/web dev",
    "clean": "rimraf node_modules pnpm-lock.yaml .pnpm-store"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "eslint": "^8.0.0",
    "fake-indexeddb": "^6.2.5",
    "pnpm": "^8.9.0",
    "rimraf": "^4.0.0",
    "typescript": "^5.1.6",
    "vitest": "^1.0.0"
  },
  "files": [],
  "repository": {
    "type": "git",
    "url": "git+https://example.com/your-org/sovereign-jedi.git"
  },
  "bugs": {
    "url": "https://example.com/your-org/sovereign-jedi/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4"
  }
}
