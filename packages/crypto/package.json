{
  "name": "@sj/crypto",
  "version": "0.1.0",
  "private": true,
  "description": "Cryptographic primitives for Sovereign Jedi — key derivation, encrypt/decrypt, integrity checks (browser + node compatible)",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir dist",
    "clean": "rimraf dist",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "prepare": "pnpm -w -r build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.1.6",
    "vitest": "^1.0.0",
    "@types/node": "^18.0.0",
    "rimraf": "^4.0.0",
    "eslint": "^8.45.0"
  }
}
