{
  "name": "@sj/ipfs",
  "version": "0.1.0",
  "private": true,
  "description": "IPFS client abstraction for Sovereign Jedi — Helia in-browser (Task 5)",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "prepare": "pnpm -w -r build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@sj/crypto": "workspace:*",
    "@chainsafe/libp2p-noise": "^16.1.4",
    "@chainsafe/libp2p-yamux": "^7.0.1",
    "@libp2p/bootstrap": "^12.0.10",
    "@libp2p/websockets": "^10.1.2",
    "helia": "^4.0.0",
    "@helia/unixfs": "^4.0.0",
    "libp2p": "^3.1.3",
    "@multiformats/multiaddr": "^12.4.1",
    "multiformats": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.1.6",
    "vitest": "^1.0.0",
    "@types/node": "^18.0.0",
    "rimraf": "^4.0.0",
    "eslint": "^8.45.0"
  }
}
